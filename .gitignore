# =====================================================
# ROOT LEVEL (General)
# =====================================================

# OS Files
.DS_Store
Thumbs.db

# Temporary Files
*.tmp
*.swp
*.bak

# Logs
logs/
*.log


# =====================================================
# BACKEND (Spring Boot - tracker/)
# =====================================================

# Build folders
tracker/target/
tracker/build/

# Compiled files
tracker/*.class
tracker/*.jar
tracker/*.war
tracker/*.ear

# Maven Wrapper (optional ignore)
tracker/.mvn/
tracker/mvnw
tracker/mvnw.cmd

# ===============================
# Application Secrets 
# ===============================

tracker/src/main/resources/application.properties
tracker/src/main/resources/application.yml
tracker/src/main/resources/application-dev.properties
tracker/src/main/resources/application-prod.properties

# Allow safe example config
!tracker/src/main/resources/application-example.yml
!tracker/src/main/resources/application-example.properties


# =====================================================
# FRONTEND (React - frontend/)
# =====================================================

# Node modules
frontend/node_modules/

# Build output
frontend/build/
frontend/dist/

# Environment variables (VERY IMPORTANT )
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local


# =====================================================
# IDE FILES
# =====================================================

# IntelliJ
.idea/
*.iml

# VS Code
.vscode/

# Eclipse
.project
.classpath
.settings/



# Coverage reports
coverage/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*